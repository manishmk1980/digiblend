# OPENROUTER_API_KEY: Preferred provider for AI API calls.
OPENROUTER_API_KEY="MY_OPENROUTER_API_KEY"
OPENROUTER_MODEL="auto:free"

# GEMINI_API_KEY: Optional fallback provider for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"
NEXT_PUBLIC_APP_URL="https://digiblend.in"

# Production auth provider placeholders. Current MVP uses local/session demo auth;
# wire these before enabling real customer authentication.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"

# Production payment provider placeholders. Current MVP uses simulated checkout;
# wire these before taking real payments.
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""
RAZORPAY_PRO_PLAN_ID=""
NEXT_PUBLIC_RAZORPAY_KEY_ID=""

# Optional future Claude/LangGraph provider. OpenRouter remains the active MVP provider.
ANTHROPIC_API_KEY=""

# Optional crawler services for the full Business Gap Analyser.
FIRECRAWL_API_URL="http://localhost:3002"
FIRECRAWL_API_KEY=""

# Public support contact details used by the chatbot and customer UI.
SUPPORT_EMAIL="support@digiblend.in"
SUPPORT_PHONE=""
SUPPORT_CALL_URL="https://digiblend.in/contact"

# MySQL database used by the backend audit pipeline.
# Production (app on VPS): DB_HOST=localhost, DB_PORT=3306
# Local dev to remote VPS: run `npm run db:tunnel`, then use DB_HOST=127.0.0.1 and DB_PORT=3307
DB_HOST="127.0.0.1"
DB_PORT="3307"
DB_NAME="digiblend_db"
DB_USER="digiblend_user"
DB_PASSWORD="CHANGE_ME"
DB_CONNECTION_LIMIT="10"
DB_CONNECT_TIMEOUT="10000"

# Prisma canonical app data-layer connection.
# Production: mysql://digiblend_user:PASSWORD@localhost:3306/digiblend_db
# Local tunnel: mysql://digiblend_user:PASSWORD@127.0.0.1:3307/digiblend_db
DATABASE_URL="mysql://digiblend_user:CHANGE_ME@127.0.0.1:3307/digiblend_db"
